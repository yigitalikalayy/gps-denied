[Unit]
Description=Raspberry Pi Optical Flow to PX4 (OPTICAL_FLOW_RAD)
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/gps-denied-navigation
ExecStart=/opt/gps-denied-navigation/scripts/executor.sh /opt/gps-denied-navigation/config.json
Restart=on-failure
RestartSec=1
User=root

[Install]
WantedBy=multi-user.target
